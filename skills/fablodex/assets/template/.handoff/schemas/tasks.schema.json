{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex/handoff/tasks.schema.json",
  "title": "Handoff task board",
  "type": "object",
  "required": [
    "id",
    "title",
    "owner",
    "status",
    "instructions",
    "acceptance_criteria",
    "qa_commands",
    "evidence_required",
    "blocked_after_attempts",
    "tasks"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "project": { "type": "string", "minLength": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "owner": {
      "type": "string",
      "enum": ["claude_fable", "codex", "lazycodex", "user"]
    },
    "status": {
      "type": "string",
      "enum": ["pending", "ready", "in_progress", "blocked", "blocked_by_fable", "complete", "cancelled", "split", "replanned"]
    },
    "instructions": { "type": "string", "minLength": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "qa_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "evidence_required": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "blocked_after_attempts": { "type": "integer", "const": 2 },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title",
        "owner",
        "status",
        "instructions",
        "acceptance_criteria",
        "qa_commands",
        "evidence_required",
        "blocked_after_attempts"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "owner": {
          "type": "string",
          "enum": ["claude_fable", "codex", "lazycodex", "user"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "ready", "in_progress", "blocked", "blocked_by_fable", "complete", "cancelled", "split", "replanned"]
        },
        "instructions": { "type": "string", "minLength": 1 },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "qa_commands": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "evidence_required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1
        },
        "blocked_after_attempts": { "type": "integer", "const": 2 },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
